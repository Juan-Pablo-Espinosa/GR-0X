        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="model://growbot_base/meshes/Hip_base.STL" />
      </geometry>
    </collision>
  </link>
  <!--dummy base link DO NOT REMOVE UYKWYD!-->
  <link name="base_link">
    <xacro:dummy_inertial/>
  </link>
  <joint
    name="base_joint"
    type="fixed">
    <parent link="base_link"/>
    <child link="Hip_base"/>
    <!--mess with blw if you want to move base location-->
    <origin
      xyz="0 0 0"
      rpy="0 0 0"/>
  </joint>

  <!--footprint for use in stuff like nav2 convience-->
  <link name="base_footprint">
    <xacro:dummy_inertial/>
  </link>
  <joint
    name="footprint_robot" type="fixed">
    <parent link="Hip_base"/>
    <child link="base_footprint"/>
  </joint>
 

