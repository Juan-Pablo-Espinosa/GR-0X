  <!-- ============================================================ -->
  <!-- Gazebo material / friction tuning                             -->
  <!-- ============================================================ -->

  <!-- Foot contact: high mu so the biped doesn't slide on ground.
       ODE params tuned for a soft-ish rubber-on-ground contact. -->
  <xacro:macro name="foot_gazebo" params="link_name">
    <gazebo reference="${link_name}">
      <mu1>1.2</mu1>
      <mu2>1.2</mu2>
      <kp>1e6</kp>
      <kd>100</kd>
      <minDepth>0.001</minDepth>
      <maxVel>0.1</maxVel>
      <fdir1>1 0 0</fdir1>
      <self_collide>false</self_collide>
    </gazebo>
  </xacro:macro>

  <xacro:foot_gazebo link_name="Feet_L"/>
  <xacro:foot_gazebo link_name="Feet_R"/>

</robot>
