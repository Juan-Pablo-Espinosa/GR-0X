<?xml version="1.0" encoding="utf-8"?>
<robot
  name="growbot"
  xmlns:xacro="http://www.ros.org/wiki/xacro" >

<!-- This URDF was automatically created by SolidWorks to URDF Exporter! Originally created by Stephen Brawner (brawner@gmail.com)
     Commit Version: 1.6.0-4-g7f85cfe  Build Version: 1.6.7995.38578
     For more information, please see http://wiki.ros.org/sw_urdf_exporter -->


<xacro:macro name="dummy_inertial">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="1e-6"/>
    <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
  </inertial>
</xacro:macro>




<xacro:arg name="use_sim" default="true"/>
<xacro:arg name="ns" default=""/>
<xacro:property name="use_sim" value="$(arg use_sim)"/>
<xacro:property name="ns" value="$(arg ns)"/>

<!-- Shared joint interface list and ros2_control-->
<xacro:macro name="growbot_joint_interfaces">

  <joint name="HPR">
    <param name="motor_id">1</param>
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  <joint name="UTR">
    <param name="motor_id">2</param>
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  <joint name="LTR">
    <param name="motor_id">3</param>
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  <joint name="FR">
    <param name="motor_id">4</param>
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  <!-- Left leg -->
  <joint name="HPL">
    <param name="motor_id">5</param>
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  <joint name="UTL">
    <param name="motor_id">6</param>
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  <joint name="LTL">
    <param name="motor_id">7</param>
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  <joint name="FL">
    <param name="motor_id">8</param>
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <!-- labeled passive for robstride as these are pololu-->
  <joint name="UBR"><param name="passive">true</param></joint>
  <joint name="LBR"><param name="passive">true</param></joint>
  <joint name="UBL"><param name="passive">true</param></joint>
  <joint name="LBL"><param name="passive">true</param></joint>
</xacro:macro>

<xacro:if value="${use_sim}">
  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find growbot_base)/config/controller.yaml</parameters>
      <xacro:if value="${ns != ''}">
        <ros>
          <namespace>${ns}</namespace>
        </ros>
      </xacro:if>
    </plugin>
  </gazebo>

  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <xacro:growbot_joint_interfaces/>
  </ros2_control>
</xacro:if>

<!-- hardware stuff-->
<xacro:unless value="${use_sim}">
  <ros2_control name="RobStrideSystem" type="system">
    <hardware>
      <plugin>growbot_hardware/RobStrideSystem</plugin>
      <param name="can_interface">can0</param>
    </hardware>
    <xacro:growbot_joint_interfaces/>
  </ros2_control>
</xacro:unless>







